<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="RentalApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:RentalApp.Views"
    Shell.FlyoutBehavior="Disabled">

    <!-- Start on Login -->
    <ShellContent
        Route="LoginPage"
        ContentTemplate="{DataTemplate views:LoginPage}" />

    <!-- Main dashboard -->
    <ShellContent
        Route="MainPage"
        ContentTemplate="{DataTemplate views:MainPage}" />

    <!-- Profile Page -->
    <ShellContent
        Route="ProfilePage"
        ContentTemplate="{DataTemplate views:ProfilePage}" />

    <!-- Settings Page -->
    <ShellContent
        Route="SettingsPage"
        ContentTemplate="{DataTemplate views:SettingsPage}" />

    <!-- Temp Page -->
    <ShellContent
        Route="TempPage"
        ContentTemplate="{DataTemplate views:TempPage}" />

    <!-- Admin pages -->
    <ShellContent
        Route="UserListPage"
        ContentTemplate="{DataTemplate views:UserListPage}" />

    <ShellContent
        Route="UserDetailPage"
        ContentTemplate="{DataTemplate views:UserDetailPage}" />

</Shell>
