<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:RentalApp.ViewModels"
    x:Class="RentalApp.Views.BrowseItemsPage"
    Title="Browse Items">

    <CollectionView
        ItemsSource="{Binding Items}"
        SelectionMode="Single"
        SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
        SelectionChangedCommand="{Binding SelectItemCommand}"
        SelectionChangedCommandParameter="{Binding SelectedItem}">

        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Frame Margin="10" Padding="10" HasShadow="True">
                    <VerticalStackLayout>
                        <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold"/>
                        <Label Text="{Binding Description}" FontSize="14"/>
                        <Label Text="{Binding Category}" FontSize="12" TextColor="Gray"/>
                    </VerticalStackLayout>
                </Frame>
            </DataTemplate>
        </CollectionView.ItemTemplate>

    </CollectionView>

</ContentPage>
