<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="RentalApp.Views.ItemDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:RentalApp.ViewModels"
    Title="Item Details">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- Item Name -->
            <Label Text="{Binding Item.Name}"
                   FontSize="28"
                   FontAttributes="Bold" />

            <!-- Description -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#DDD, Dark=#444}"
                    Padding="15"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                <Label Text="{Binding Item.Description}"
                       FontSize="16" />
            </Border>

            <!-- Category -->
            <Label Text="Category"
                   FontSize="14"
                   FontAttributes="Bold" />
            <Label Text="{Binding Item.Category}"
                   FontSize="14"
                   TextColor="Gray" />

            <!-- Owner -->
            <Label Text="Owner"
                   FontSize="14"
                   FontAttributes="Bold" />
            <Label Text="{Binding Item.OwnerName}"
                   FontSize="14"
                   TextColor="Gray" />

            <!-- Rent Button -->
            <Button Text="Rent This Item"
                    Command="{Binding RentItemCommand}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                    TextColor="White"
                    CornerRadius="8"
                    HeightRequest="50" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
