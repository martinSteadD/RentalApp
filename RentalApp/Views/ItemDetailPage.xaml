<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="RentalApp.Views.ItemDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:RentalApp.ViewModels"
    Title="Item Details">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- Item Title -->
            <Label Text="{Binding Item.Title}"
                   FontSize="28"
                   FontAttributes="Bold" />

            <!-- Description -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#DDD, Dark=#444}"
                    Padding="15"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                <Label Text="{Binding Item.Description}"
                       FontSize="16" />
            </Border>

            <!-- Category -->
            <Label Text="Category"
                   FontSize="14"
                   FontAttributes="Bold" />
            <Label Text="{Binding Item.Category}"
                   FontSize="14"
                   TextColor="Gray" />

            <!-- Owner -->
            <Label Text="Owner"
                   FontSize="14"
                   FontAttributes="Bold" />
            <Label Text="{Binding Item.OwnerName}"
                   FontSize="14"
                   TextColor="Gray" />

              <!-- Daily Rate -->
              <Label Text="Daily Rate"
                     FontSize="14"
                     FontAttributes="Bold" />
              <Label Text="{Binding Item.DailyRate, StringFormat='£{0:F2} per day'}"
                     FontSize="14"
                     TextColor="Gray" />

              <!-- Availability -->
              <Label Text="Availability"
                     FontSize="14"
                     FontAttributes="Bold" />
              <Label Text="{Binding Item.IsAvailable, Converter={StaticResource BoolToAvailabilityConverter}}"
                     FontSize="14"
                     TextColor="Gray" />

              <!-- Owner Rating -->
              <Label Text="Owner Rating"
                     FontSize="14"
                     FontAttributes="Bold" />
              <Label Text="{Binding Item.OwnerRating, StringFormat='{0:F1} ★'}"
                     FontSize="14"
                     TextColor="Gray" />

              <!-- Created Date -->
              <Label Text="Listed On"
                     FontSize="14"
                     FontAttributes="Bold" />
              <Label Text="{Binding Item.CreatedAt, StringFormat='{0:dd MMM yyyy}'}"
                     FontSize="14"
                     TextColor="Gray" />

              <!-- Distance (placeholder for later) -->
              <Label Text="Distance"
                     FontSize="14"
                     FontAttributes="Bold" />
              <Label Text="Calculating..."
                     FontSize="14"
                     TextColor="Gray" />



            <!-- Rent Button -->
            <Button Text="Rent This Item"
                    Command="{Binding RentItemCommand}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                    TextColor="White"
                    CornerRadius="8"
                    HeightRequest="50" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
