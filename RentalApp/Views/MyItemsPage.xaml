<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="RentalApp.Views.MyItemsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="My Items">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Add"
                     IconImageSource="add.png"
                     Command="{Binding GoToCreateItemCommand}" />
    </ContentPage.ToolbarItems>

    <RefreshView IsRefreshing="{Binding IsBusy}"
                 Command="{Binding LoadMyItemsCommand}">
        <CollectionView
            ItemsSource="{Binding MyItems}"
            SelectionMode="Single"
            SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
            SelectionChangedCommand="{Binding SelectItemCommand}"
            SelectionChangedCommandParameter="{Binding SelectedItem}">

            <CollectionView.EmptyView>
                <VerticalStackLayout Padding="20" Spacing="10">
                    <Label Text="You haven't added any items yet."
                           FontSize="16"
                           HorizontalOptions="Center" />
                    <Button Text="Add Your First Item"
                            Command="{Binding GoToCreateItemCommand}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                            TextColor="White"
                            CornerRadius="8" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="10" Padding="15" StrokeThickness="1"
                            Stroke="{AppThemeBinding Light=#DDD, Dark=#444}"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                        <VerticalStackLayout>
                            <Label Text="{Binding Title}"
                                FontSize="18"
                                FontAttributes="Bold" />

                            <Label Text="{Binding Description}"
                                FontSize="14"
                                TextColor="Gray" />

                            <!-- FIXED: CategoryName instead of Category -->
                            <Label Text="{Binding CategoryName}"
                                FontSize="12"
                                TextColor="DarkGray" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </RefreshView>

</ContentPage>
